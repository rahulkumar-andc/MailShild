# MailShield AI Environment Variables
DJANGO_SECRET_KEY=django-insecure-dummy-key-for-dev
DEBUG=True

# Gmail IMAP Credentials
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Instagram Credentials
INSTA_USER=your-insta-username
INSTA_PASSWORD=your-insta-password

# Anthropic Claude
ANTHROPIC_API_KEY=your-claude-api-key

# ntfy.sh config
NTFY_TOPIC=mailshield_ai_alerts_random_1337

# Redis/Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# App behavior
DRY_RUN=True
